# ========================================
# AUTOESCOLA SAAS - CONFIGURAÇÃO PRODUÇÃO
# ========================================

# Database
DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/autoescola_saas
DIRECT_URL=postgresql://user:password@prod-db.example.com:5432/autoescola_saas

# Redis
REDIS_HOST=prod-redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=seu-password-redis

# OpenAI
OPENAI_API_KEY=sk-prod-xxxxx

# WhatsApp
WHATSAPP_WEBHOOK_TOKEN=seu-token-webhook-seguro
WHATSAPP_BUSINESS_ACCOUNT_ID=seu-business-account-id
WHATSAPP_BUSINESS_PHONE_ID=seu-phone-id
WHATSAPP_ACCESS_TOKEN=seu-access-token

# JWT
JWT_SECRET=seu-secret-jwt-super-seguro-aleatorio

# OAuth Manus
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im
VITE_APP_ID=seu-app-id

# Manus Built-in APIs
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=seu-api-key

# Owner Info
OWNER_OPEN_ID=seu-owner-open-id
OWNER_NAME=Seu Nome

# Environment
NODE_ENV=production
PORT=3000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGIN=https://seu-frontend.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (Opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=seu-app-password
SMTP_FROM=noreply@autoescola-saas.com

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_ENDPOINT=https://analytics.example.com

# Sentry (Error Tracking)
SENTRY_DSN=https://seu-sentry-dsn

# S3 Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=seu-access-key
AWS_SECRET_ACCESS_KEY=seu-secret-key
AWS_S3_BUCKET=autoescola-saas-prod

# Stripe (Opcional)
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Twilio (Opcional para SMS)
TWILIO_ACCOUNT_SID=seu-account-sid
TWILIO_AUTH_TOKEN=seu-auth-token
TWILIO_PHONE_NUMBER=+55xxxxx

# Backup
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# Security
ENABLE_2FA=true
SESSION_TIMEOUT=3600000
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# API Rate Limiting
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Webhook Rate Limiting
WEBHOOK_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Monitoring
MONITORING_ENABLED=true
MONITORING_INTERVAL_SECONDS=60
